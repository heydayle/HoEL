{
  "extends": [
    "next/core-web-vitals",
    "plugin:@typescript-eslint/recommended",
    "plugin:jsdoc/recommended-typescript-error",
    "prettier"
  ],
  "plugins": [
    "@typescript-eslint",
    "jsdoc",
    "unused-imports",
    "eslint-comments"
  ],
  "rules": {
    // 🚫 Cấm sử dụng any
    "@typescript-eslint/no-explicit-any": "error",

    // 🚫 Cấm disable eslint (Trừ khi bất khả kháng thì phải dùng eslint-disable-next-line kèm comment giải thích, nhưng mặc định chặn gắt)
    "eslint-comments/no-use": [
      "error",
      {
        "allow": []
      }
    ],

    // 🧹 Tự động xóa import thừa và báo lỗi biến không sử dụng
    "unused-imports/no-unused-imports": "error",
    "unused-imports/no-unused-vars": [
      "error",
      {
        "vars": "all",
        "varsIgnorePattern": "^_",
        "args": "after-used",
        "argsIgnorePattern": "^_"
      }
    ],

    // 📝 Bắt buộc phải có JSDoc (/** ... */)
    "jsdoc/require-jsdoc": [
      "error",
      {
        "require": {
          "FunctionDeclaration": true,
          "MethodDefinition": true,
          "ClassDeclaration": true,
          "ArrowFunctionExpression": true,
          "FunctionExpression": true
        }
      }
    ],
    "jsdoc/require-param": "error",
    "jsdoc/require-returns": "error",
    "jsdoc/require-description": "error",

    // 💡 Các rule Clean Code cơ bản
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "prefer-const": "error",
    "eqeqeq": ["error", "always"]
  }
}
